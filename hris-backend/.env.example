# Salin file ini jadi .env lalu sesuaikan.

# Development di laptop (default) — pakai SQLite, tidak perlu install apa-apa.
DATABASE_URL=sqlite:///./hris.db

# Produksi — PostgreSQL (uncomment & sesuaikan, butuh psycopg di requirements):
# DATABASE_URL=postgresql+psycopg://hris_user:password@localhost:5432/hris

CORS_ORIGINS=http://localhost:3000
